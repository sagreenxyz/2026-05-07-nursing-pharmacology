---
import '../../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Autonomic Nervous System Drugs</title>
	</head>
	<body class="min-h-screen bg-base-200">
		<div class="navbar bg-base-100 shadow-sm">
			<div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4">
				<a class="btn btn-ghost text-lg normal-case">Nursing Pharmacology</a>
				<a href="../" class="btn btn-sm btn-outline">Back</a>
			</div>
		</div>

		<main class="mx-auto grid w-full max-w-6xl gap-6 px-4 py-10">
			<section class="hero rounded-box bg-base-100 shadow-xl">
				<div class="hero-content py-12 text-center">
					<div class="max-w-3xl space-y-5">
						<div class="badge badge-primary badge-outline">Module Placeholder</div>
						<h1 class="text-4xl font-bold md:text-5xl">Autonomic Nervous System</h1>
						<p class="text-base-content/80">
							Content data has been removed. This page now serves as a clean shell for the
							structure you will provide.
						</p>
					</div>
				</div>
			</section>

			<section class="card bg-base-100 shadow-md">
				<div class="card-body gap-4">
					<h2 class="card-title">Lectures</h2>
					<p class="text-base-content/80">
						Open the current lecture directly from this module page.
					</p>
					<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
						<article class="card border border-base-300 bg-base-100">
							<div class="card-body gap-3">
								<div class="badge badge-primary badge-outline">Lecture 1</div>
								<h3 class="card-title text-lg">ANS Physiology Review</h3>
								<p class="text-sm text-base-content/80">
									Foundational overview of sympathetic vs parasympathetic anatomy,
									neurotransmitters, receptor subtypes, and agonist/antagonist reasoning.
								</p>
								<div class="card-actions justify-end">
									<a href={`${import.meta.env.BASE_URL}autonomic-nervous-system/lecture-1/`} class="btn btn-primary btn-sm">
										Open Lecture
									</a>
								</div>
							</div>
						</article>

						<article class="card border border-base-300 bg-base-100">
							<div class="card-body gap-3">
								<div class="badge badge-secondary badge-outline">Lecture 2</div>
								<h3 class="card-title text-lg">Adrenergic Agonists I: Catecholamines</h3>
								<p class="text-sm text-base-content/80">
									Clinical application of epinephrine, norepinephrine, dopamine,
									dobutamine, and isoproterenol with nursing monitoring priorities.
								</p>
								<div class="card-actions justify-end">
									<a href={`${import.meta.env.BASE_URL}autonomic-nervous-system/lecture-2/`} class="btn btn-secondary btn-sm">
										Open Lecture
									</a>
								</div>
							</div>
						</article>

						<article class="card border border-base-300 bg-base-100">
							<div class="card-body gap-3">
								<div class="badge badge-accent badge-outline">Lecture 3</div>
								<h3 class="card-title text-lg">Adrenergic Agonists II: Non-Catecholamines</h3>
								<p class="text-sm text-base-content/80">
									Applied selectivity across phenylephrine, pseudoephedrine,
									albuterol, salmeterol, terbutaline, and midodrine.
								</p>
								<div class="card-actions justify-end">
									<a href={`${import.meta.env.BASE_URL}autonomic-nervous-system/lecture-3/`} class="btn btn-accent btn-sm">
										Open Lecture
									</a>
								</div>
							</div>
						</article>

						<article class="card border border-base-300 bg-base-100">
							<div class="card-body gap-3">
								<div class="badge badge-neutral badge-outline">Lecture 4</div>
								<h3 class="card-title text-lg">Alpha-Adrenergic Blockers</h3>
								<p class="text-sm text-base-content/80">
									Non-selective and selective alpha blockade, BPH and hypertension roles,
									pheochromocytoma sequencing, and first-dose orthostatic safety.
								</p>
								<div class="card-actions justify-end">
									<a href={`${import.meta.env.BASE_URL}autonomic-nervous-system/lecture-4/`} class="btn btn-neutral btn-sm">
										Open Lecture
									</a>
								</div>
							</div>
						</article>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>
